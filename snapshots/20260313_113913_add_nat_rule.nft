table inet filter {
	set ssh_allow4 {
		type ipv4_addr
		flags interval
		elements = { 31.43.144.0/20, 91.210.240.0/22,
			     91.210.248.0/22, 100.64.0.0/10,
			     127.0.0.1, 176.111.176.0/21,
			     176.111.184.0/22, 176.111.190.0/24 }
	}

	chain input {
		type filter hook input priority filter; policy drop;
		ct state { established, related } accept
		ct state invalid drop
		iif "lo" accept
		ip protocol icmp accept
		ip6 nexthdr ipv6-icmp accept
		iifname "tailscale0" accept
		udp dport 41641 accept
		tcp dport 54322 accept
		udp dport 53 limit rate 20/second burst 50 packets accept
		tcp dport 53 limit rate 20/second burst 50 packets accept
		udp dport 853 accept
		tcp dport 853 accept
		tcp dport { 80, 443 } accept
		tcp dport 5061 accept
		udp dport 10000-19999 accept
		tcp dport 3001 accept
		counter packets 26165 bytes 2201087
		tcp dport 5050 accept
	}

	chain forward {
		type filter hook forward priority filter; policy drop;
		ct state { established, related } accept
		ct state invalid drop
		iifname "tailscale0" oifname "eth0" accept
		iifname "docker0" accept
		oifname "docker0" accept
		iifname "br-*" accept
		oifname "br-*" accept
		log prefix "NFT_DROP_FWD: "
		ip daddr 172.19.0.22 tcp dport 3333 counter packets 0 bytes 0 accept
	}
}
table inet f2b_global {
	set banned4 {
		type ipv4_addr
		elements = { 187.157.88.115, 187.157.88.116 }
	}

	set banned6 {
		type ipv6_addr
	}

	chain input {
		type filter hook input priority -100; policy accept;
		ip saddr @banned4 counter packets 208419 bytes 13909847 drop
		ip6 saddr @banned6 counter packets 0 bytes 0 drop
	}

	chain forward {
		type filter hook forward priority -100; policy accept;
		ip saddr @banned4 counter packets 0 bytes 0 drop
		ip6 saddr @banned6 counter packets 0 bytes 0 drop
	}
}
table ip nat {
	chain PREROUTING {
		type nat hook prerouting priority dstnat; policy accept;
		fib daddr type local counter packets 712173 bytes 43221509 jump DOCKER
	}

	chain OUTPUT {
		type nat hook output priority dstnat; policy accept;
		ip daddr != 127.0.0.0/8 fib daddr type local counter packets 10140 bytes 625144 jump DOCKER
	}

	chain POSTROUTING {
		type nat hook postrouting priority srcnat; policy accept;
		ip saddr 172.17.0.0/16 oifname != "docker0" counter packets 61 bytes 9272 masquerade
		ip saddr 172.18.0.0/16 oifname != "br-97ae768072cb" counter packets 2113 bytes 133864 masquerade
		counter packets 880396 bytes 90116222 jump ts-postrouting
		ip saddr 172.19.0.0/16 oifname != "br-18aaf031ee6d" counter packets 191643 bytes 15131988 masquerade
		ip saddr 100.64.0.0/10 oifname "eth0" counter packets 0 bytes 0 masquerade
	}

	chain ts-postrouting {
		meta mark & 0x00ff0000 == 0x00040000 counter packets 14827 bytes 10160080 masquerade
	}

	chain DOCKER {
		iifname != "br-97ae768072cb" tcp dport 3552 counter packets 2 bytes 120 dnat to 172.18.0.2:3552
		iifname != "br-18aaf031ee6d" tcp dport 3001 counter packets 0 bytes 0 dnat to 172.19.0.2:3001
	}
}
