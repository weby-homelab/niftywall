		ip daddr 172.18.0.2 iifname != "br-97ae768072cb" oifname "br-97ae768072cb" tcp dport 3552 counter packets 2 bytes 120 accept
		iifname != "br-18aaf031ee6d" oifname "br-18aaf031ee6d" counter packets 0 bytes 0 drop
		iifname != "br-97ae768072cb" oifname "br-97ae768072cb" counter packets 0 bytes 0 drop
