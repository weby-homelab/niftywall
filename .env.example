# ============================================================================
# NiftyWall Hardened - Environment Configuration
# ============================================================================
# Copy this file to .env and fill in the values before running Docker Compose.
# Never commit .env to version control (already in .gitignore).
#
# Required variables:
#   SECRET_KEY        - JWT signing key (must be unique per deployment)
#
# Optional variables:
#   DATA_DIR          - Path for SQLite DB and internal data (default: data)
#   SNAPSHOT_DIR      - Path for firewall snapshot backups (default: snapshots)
#   PANIC_ALLOWED_PORTS   - Comma-separated ports SAFE Mode allows through
#   PANIC_ALLOWED_INTERFACES - Comma-separated interfaces allowed in SAFE Mode
#   TZ                - Timezone for logs and UI timestamps
# ============================================================================

# ----------------------------------------------------------------------------
# 🔐 Security
# ----------------------------------------------------------------------------
# Generate a cryptographically random 64-char hex string:
#   openssl rand -hex 32
# This key signs all JWT authentication tokens. Changing it invalidates all
# active sessions.
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# ----------------------------------------------------------------------------
# 🕐 Timezone
# ----------------------------------------------------------------------------
# Controls log timestamps and UI time display. Default: Europe/Kyiv.
TZ=Europe/Kyiv

# ----------------------------------------------------------------------------
# 🛡️ Panic / SAFE Mode
# ----------------------------------------------------------------------------
# Comma-separated list of TCP/UDP ports that remain accessible when SAFE Mode
# is activated. All other ports are flushed from the nftables table.
# Default: 22,8080,54322
PANIC_ALLOWED_PORTS=22,80,443

# Comma-separated list of network interfaces allowed through in SAFE Mode.
# Default: lo,tailscale0
PANIC_ALLOWED_INTERFACES=lo,tailscale0

# ----------------------------------------------------------------------------
# 📁 Data Directories (optional — defaults are used if omitted)
# ----------------------------------------------------------------------------
# Directory inside the container where SQLite DB and internal state are stored.
# DATA_DIR=data

# Directory inside the container where firewall snapshot backups are stored.
# SNAPSHOT_DIR=snapshots

# ----------------------------------------------------------------------------
# 📱 Telegram Notifications (optional)
# ----------------------------------------------------------------------------
# Uncomment and fill in to receive SAFE Mode and firewall event alerts via
# Telegram. Requires a bot created via @BotFather.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# ----------------------------------------------------------------------------
# 🐳 Docker Hub (for CI/CD workflows only — not needed for running the app)
# ----------------------------------------------------------------------------
# DOCKER_HUB_USERNAME=
# DOCKER_HUB_PASSWORD=

# ----------------------------------------------------------------------------
# 🐙 GitHub (for CI/CD workflows only — not needed for running the app)
# ----------------------------------------------------------------------------
# GITHUB_RELEASE_TOKEN=
